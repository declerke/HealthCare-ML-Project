# ── Healthcare App ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/healthcare_db

MODEL_PATH=models/model.joblib
ENCODERS_PATH=models/encoders.joblib

SECRET_KEY=changeme_use_openssl_rand_hex_32
RETRAIN_API_KEY=changeme_random_secret

# ── Apache Airflow 3 (Docker Compose only) ───────────────────────────────────
# Generate a Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=changeme_generate_fernet_key
AIRFLOW__WEBSERVER__SECRET_KEY=changeme_random_secret

# Path where the project is mounted inside the Airflow containers
AIRFLOW_PROJECT_ROOT=/opt/airflow/project
